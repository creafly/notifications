# ===========================================
# Notifications Service Configuration
# ===========================================

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
GIN_MODE=debug  # Use 'release' in production

# Database (REQUIRED)
DATABASE_URL=postgres://notifications:password@localhost:5433/notifications?sslmode=disable
AUTO_MIGRATE=true

# Identity Service (for centralized authentication)
IDENTITY_SERVICE_URL=http://localhost:8080

# Kafka Configuration
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=notifications-service

# Outbox Configuration
OUTBOX_ENABLED=true
OUTBOX_POLL_INTERVAL=1s
OUTBOX_BATCH_SIZE=100
OUTBOX_CLEANUP_INTERVAL=1h
OUTBOX_RETENTION_PERIOD=24h
OUTBOX_FAILED_RETENTION_PERIOD=168h

# CORS Configuration (required in production)
# Comma-separated list of allowed origins
# Leave empty for development (allows all origins)
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=true

# Localization
DEFAULT_LOCALE=en-US

# Logging
LOG_LEVEL=info

# Tracing (OpenTelemetry)
TRACING_ENABLED=false
OTLP_ENDPOINT=localhost:4317
SERVICE_VERSION=1.0.0
ENVIRONMENT=development
